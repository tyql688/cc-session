{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "src/**/*.css",
      "!src/components/**",
      "src/components/icons.tsx",
      "src/components/CodeBlock.tsx",
      "src/components/MermaidBlock.tsx",
      "src/components/MessageBubble/markdown/renderers.tsx",
      "src/components/MessageBubble/markdown/utils.tsx",
      "src/components/MessageBubble/markdown/parser.ts",
      "src/components/MessageBubble/markdown/katex.ts",
      "src/components/MessageBubble/markdown/types.ts",
      "src/components/MessageBubble/MarkdownRenderer.tsx",
      "src/components/MessageBubble/ImagePreview.tsx",
      "src/components/MessageBubble/TokenUsage.tsx",
      "src/components/MessageBubble/ThinkingBlock.tsx",
      "!**/*.test.ts",
      "!**/*.test.tsx"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "assist": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useButtonType": "off",
        "noSvgWithoutTitle": "off",
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noArrayIndexKey": "off"
      }
    }
  }
}
