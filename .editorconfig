root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Rust — matches rustfmt (4-space)
[*.rs]
indent_style = space
indent_size = 4

# Frontend + config — matches Biome (2-space)
[*.{ts,tsx,js,jsx,mjs,cjs,css,json,jsonc,yml,yaml}]
indent_style = space
indent_size = 2

# Markdown: trailing whitespace is significant (two-space line breaks)
[*.md]
trim_trailing_whitespace = false
